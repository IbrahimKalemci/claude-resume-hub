{
  "name": "claude-resume-hub",
  "version": "1.6.0",
  "description": "Run Claude Code and auto-continue the moment a usage/session limit resets — with a live dashboard and desktop alerts. Cross-platform, zero-dependency.",
  "bin": {
    "claude-resume-hub": "bin/cli.js",
    "crh": "bin/cli.js"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "bin",
    "lib",
    "app",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --test",
    "build:bundle": "esbuild bin/cli.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist/bundle.cjs",
    "build:exe": "node scripts/build-exe.js",
    "app:start": "electron app/main.js",
    "app:build": "node scripts/make-icon.js && electron-builder --win portable"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "rate-limit",
    "usage-limit",
    "session-limit",
    "auto-resume",
    "automation",
    "continue"
  ],
  "author": "Ibrahim Kalemci",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IbrahimKalemci/claude-resume-hub.git"
  },
  "bugs": {
    "url": "https://github.com/IbrahimKalemci/claude-resume-hub/issues"
  },
  "homepage": "https://github.com/IbrahimKalemci/claude-resume-hub#readme",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "main": "app/main.js",
  "build": {
    "appId": "com.ibrahimkalemci.claude-resume-hub",
    "productName": "claude-resume-hub",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "app/**/*",
      "lib/**/*",
      "package.json"
    ],
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "claude-resume-hub.exe"
    }
  }
}
